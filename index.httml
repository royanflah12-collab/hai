<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Untuk Kamu ❤️</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:linear-gradient(180deg,#0f172a,#1e293b,#000);
min-height:100vh;
overflow-x:hidden;
color:white;
text-align:center;
}

.stars{
position:fixed;
width:100%;
height:100%;
background:
radial-gradient(white 1px, transparent 1px);
background-size:40px 40px;
opacity:.35;
z-index:-1;
}

.container{
padding:40px 20px;
}

.photo{
width:260px;
height:260px;
object-fit:cover;
border-radius:25px;
border:4px solid rgba(255,255,255,.3);
box-shadow:0 0 30px rgba(255,255,255,.3);
margin:25px auto;
display:block;
}

.title{
font-size:2.5rem;
font-weight:bold;
margin-top:30px;
}

.typing{
font-size:1.3rem;
color:#ffb6c1;
margin:20px 0;
min-height:40px;
}

.card{
max-width:700px;
margin:auto;
background:rgba(255,255,255,.08);
backdrop-filter:blur(15px);
padding:25px;
border-radius:25px;
line-height:1.8;
}

button{
padding:15px 30px;
margin:15px;
border:none;
border-radius:50px;
cursor:pointer;
font-size:1rem;
font-weight:bold;
}

.music-btn{
background:#ff4d6d;
color:white;
}

.gift-btn{
background:white;
color:#111;
}

.hidden{
display:none;
}

#gift{
margin-top:20px;
font-size:1.3rem;
color:#ffd166;
}

.heart{
position:fixed;
bottom:-20px;
animation:float 8s linear infinite;
}

@keyframes float{
0%{
transform:translateY(0);
opacity:1;
}
100%{
transform:translateY(-120vh);
opacity:0;
}
}
</style>
</head>
<body>

<div class="stars"></div>

<div class="container">

<h1 class="title">❤️ Untuk Kamu ❤️</h1>

<div class="typing" id="typing"></div>

<img src="FOTO_KITA.jpg" class="photo">

<div class="card">
<p>
Hai Sayang ❤️
<br><br>

Aku membuat halaman kecil ini khusus untukmu.

Mungkin ini hanya sebuah website sederhana,
tetapi setiap barisnya dibuat dengan satu tujuan:

membuatmu tersenyum hari ini. 😊

Terima kasih sudah hadir,
terima kasih sudah bertahan,
dan terima kasih karena selalu menjadi seseorang yang berarti.

❤️
</p>
</div>

<button class="music-btn" onclick="playMusic()">
🎵 Putar Lagu
</button>

<button class="gift-btn" onclick="showGift()">
🎁 Ada Sesuatu Untukmu
</button>

<div id="gift" class="hidden">
✨ Kamu adalah hadiah terindah yang pernah datang dalam hidupku ❤️
</div>

<audio id="music">
<source src="music.mp3" type="audio/mpeg">
</audio>

</div>

<script>

const text =
"Hai Cantik ❤️ Terima kasih sudah membuka halaman ini...";

let i = 0;

function typing(){
if(i < text.length){
document.getElementById("typing").innerHTML += text.charAt(i);
i++;
setTimeout(typing,60);
}
}

typing();

function playMusic(){
document.getElementById("music").play();
}

function showGift(){
document.getElementById("gift").classList.remove("hidden");
}

function createHeart(){

const heart=document.createElement("div");

heart.className="heart";
heart.innerHTML="❤️";

heart.style.left=Math.random()*100+"vw";
heart.style.fontSize=(Math.random()*25+15)+"px";

document.body.appendChild(heart);

setTimeout(()=>{
heart.remove();
},8000);
}

setInterval(createHeart,500);

</script>

</body>
</html>